{
    "env": {
        "commonjs": true,
        "es6": true,
        "node": true
    },
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
        "ecmaVersion": 2020,
        "sourceType": "module"
    },
    "extends": [
        "plugin:@typescript-eslint/recommended"
    ],
    "rules": {
        "semi": ["error", "always"],
        "quotes": [2, "single", { "avoidEscape": true }],
        "@typescript-eslint/no-non-null-assertion": "off"
    }
}
