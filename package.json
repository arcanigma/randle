{
    "name": "randle",
    "description": "Dice, cards, and polling bot for Slack.",
    "version": "3.2.1",
    "main": "./dist/app.js",
    "scripts": {
        "build": "tsc",
        "lint": "eslint ./src/ --fix",
        "start": "node --enable-source-maps ./dist/app.js",
        "dev": "ts-node-dev --inspect --poll --interval 1000 --respawn --rs --transpile-only --watch -r dotenv/config ./src/app.ts"
    },
    "engines": {
        "node": "^14"
    },
    "dependencies": {
        "@slack/bolt": "^2.3",
        "@slack/web-api": "^5.12",
        "cytoscape": "^3.16",
        "got": "^11.7",
        "json5": "^2.1",
        "mongodb": "^3.6",
        "ordinal": "^1.0",
        "php-random-int": "^1.0",
        "puppeteer": "^5.3"
    },
    "devDependencies": {
        "@tsconfig/node12": "*",
        "@types/cytoscape": "*",
        "@types/json5": "*",
        "@types/mongodb": "*",
        "@types/node": "*",
        "@types/puppeteer-core": "*",
        "@typescript-eslint/eslint-plugin": "*",
        "@typescript-eslint/parser": "*",
        "dotenv": "^8.2",
        "eslint": "^7.9",
        "ts-node-dev": "^1.0.0-pre.62",
        "typescript": "^4.0"
    },
    "license": "MIT",
    "author": {
        "name": "Arcanigma Foundation",
        "email": "randle@arcanigma.org",
        "url": "https://github.com/arcanigma"
    },
    "repository": "github:arcanigma/randle",
    "private": true
}
