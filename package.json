{
    "name": "randle",
    "description": "Dice rolling and game randomization bot for Slack.",
    "version": "3.1.0",
    "main": "dist/app.js",
    "scripts": {
        "build": "tsc",
        "start": "node --enable-source-maps dist/app.js",
        "dev": "tsc && node --enable-source-maps -r dotenv/config dist/app.js"
    },
    "engines": {
        "node": "^12.x"
    },
    "dependencies": {
        "@slack/bolt": "^2.1",
        "@slack/web-api": "^5.11.0",
        "got": "^11.5.1",
        "json5": "^2.1",
        "mongodb": "^3.5",
        "ordinal": "*",
        "php-random-int": "^1.0"
    },
    "devDependencies": {
        "@types/json5": "^0.0",
        "@types/mongodb": "^3.5",
        "@types/node": "^14.0.26",
        "@typescript-eslint/eslint-plugin": "^3.7.0",
        "@typescript-eslint/parser": "^3.7.0",
        "dotenv": "^8.2",
        "eslint": "^7.5.0",
        "ngrok": "^3.2",
        "typescript": "^3.9.7"
    },
    "license": "MIT",
    "author": {
        "name": "Ron Reaser",
        "email": "ron@reaser.org",
        "url": "https://github.com/ron-reaser"
    },
    "repository": "github:ron-reaser/randle",
    "private": true
}
