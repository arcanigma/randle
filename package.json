{
    "name": "randle",
    "description": "Dice, cards, and polling bot for Slack.",
    "version": "3.4.0",
    "main": "./dist/app.js",
    "scripts": {
        "build": "tsc",
        "lint": "eslint ./src/ --fix",
        "start": "node --enable-source-maps ./dist/app.js",
        "dev": "ts-node-dev --inspect --poll --interval 1000 --respawn --rs --transpile-only --watch -r dotenv/config ./src/app.ts"
    },
    "engines": {
        "node": "^14"
    },
    "dependencies": {
        "@slack/bolt": "^2.4.1",
        "@slack/web-api": "^5.13.0",
        "cytoscape": "^3.16.3",
        "got": "^11.8.0",
        "json5": "^2.1",
        "mongodb": "^3.6",
        "ordinal": "^1.0",
        "php-random-int": "^1.0",
        "puppeteer": "^5.4.1"
    },
    "devDependencies": {
        "@tsconfig/node12": "*",
        "@types/cytoscape": "^3.14.8",
        "@types/json5": "*",
        "@types/mongodb": "^3.5.32",
        "@types/node": "^14.14.6",
        "@types/puppeteer-core": "*",
        "@typescript-eslint/eslint-plugin": "^4.6.0",
        "@typescript-eslint/parser": "^4.6.0",
        "dotenv": "^8.2",
        "eslint": "^7.12.1",
        "ts-node-dev": "^1.0.0-pre.62",
        "typescript": "^4.0.5"
    },
    "license": "MIT",
    "author": {
        "name": "Arcanigma Foundation",
        "email": "randle@arcanigma.org",
        "url": "https://github.com/arcanigma"
    },
    "repository": "github:arcanigma/randle",
    "private": true
}
