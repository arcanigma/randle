{
    "name": "randle",
    "description": "Dice, cards, and polling bot for Slack.",
    "version": "3.2.0",
    "main": "./dist/app.js",
    "scripts": {
        "lint": "eslint ./src/ --fix",
        "build": "tsc",
        "start": "node --enable-source-maps ./dist/app.js",
        "dev": "node --enable-source-maps -r dotenv/config ./dist/app.js"
