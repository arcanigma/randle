        "got": "*",
        "json5": "*",
        "mongodb": "*",
        "ordinal": "*",
        "php-random-int": "*",
        "puppeteer": "*"
    },
    "devDependencies": {
        "@tsconfig/node12": "*",
        "@types/cytoscape": "*",
        "@types/json5": "*",
        "@types/mongodb": "*",
        "@types/node": "*",
        "@types/puppeteer-core": "*",
        "@typescript-eslint/eslint-plugin": "*",
        "@typescript-eslint/parser": "*",
        "dotenv": "*",
        "eslint": "*",
        "typescript": "*"
    },
